generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingSlot {
  MORNING
  AFTERNOON
  FULL_DAY
}

enum WeatherSource {
  PRESET
  CUSTOM
}

model Booking {
  id             String        @id @default(cuid())
  bookingDate    DateTime      @db.Date
  locationKey    String
  locationLabel  String
  locationPath   String[]
  locationScope  String
  slot           BookingSlot
  weatherLabel   String
  weatherSource  WeatherSource
  bookedBy       String
  occasion       String?
  accessCodeHash String
  createdAt      DateTime      @default(now())

  @@unique([locationKey, bookingDate, slot])
  @@index([bookingDate])
  @@index([locationKey, bookingDate])
}
