generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingSlot {
  MORNING
  AFTERNOON
  FULL_DAY
}

enum WeatherSource {
  PRESET
  CUSTOM
}

model Booking {
  id            String        @id @default(cuid())
  bookingDate   DateTime      @db.Date
  slot          BookingSlot
  weatherLabel  String
  weatherSource WeatherSource
  bookedBy      String
  accessCodeHash String
  createdAt     DateTime      @default(now())

  @@unique([bookingDate, slot])
  @@index([bookingDate])
}
